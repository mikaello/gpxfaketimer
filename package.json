{
  "name": "@mikaello/gpxfaketimer",
  "version": "0.1.0",
  "description": "Create (or modify) timestamps in a GPX file",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "bin": {
    "gpxfaketimer": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist/",
    "build": "tsc -b",
    "prepublishOnly": "npm run build",
    "test": "node --import './__tests__/setup.ts' --test '__tests__/**/*.spec.ts'"
  },
  "author": "mikaello",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikaello/gpxfaketimer.git"
  },
  "bugs": {
    "url": "https://github.com/mikaello/gpxfaketimer/issues"
  },
  "homepage": "https://github.com/mikaello/gpxfaketimer#readme",
  "keywords": [
    "gps",
    "gpx",
    "timestamps"
  ],
  "browserslist": [
    "last 1 Chrome versions"
  ],
  "prettier": {
    "trailingComma": "all",
    "proseWrap": "always"
  },
  "dependencies": {
    "@xmldom/xmldom": "0.9.9"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "6.0.2"
  }
}
